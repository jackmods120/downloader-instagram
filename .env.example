# ── پێویستەکان / Required ──────────────────────────────────────────────────────
BOT_TOKEN=TOKEN_BOTFATHERت_لێرە_بنووسە

# ── ئایدیی خۆت / Your Telegram ID ─────────────────────────────────────────────
# بۆ زانینی ئایدیت، بنووسە /start بۆ @userinfobot
OWNER_ID=ئایدیی_تیلیگرامت

# ── ئارەزووی (Optional) ────────────────────────────────────────────────────────
# بۆ خەزن کردنی داتا (بەکارهێنەر، stats...) — بەبێ ئەمەش کار دەکات
# لە firebase.google.com دروستی بکە
DB_URL=https://your-project.firebaseio.com
DB_SECRET=your_firebase_secret

# ── زانیاری بۆت ────────────────────────────────────────────────────────────────
DEV_USERNAME=@یوزەرنەیمت
CHANNEL_URL=https://t.me/چەناڵەکەت
